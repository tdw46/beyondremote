CPANEL_HOST=https://your-cpanel-host:2083
CPANEL_USER=your_cpanel_username
CPANEL_TOKEN=replace_with_a_new_rotated_token
CPANEL_DOMAIN=api.beyondstudios.us

# Database choice for the sync backend.
SYNC_DB_DRIVER=pgsql
SYNC_DB_NAME=beyondremote_sync
SYNC_DB_USER=beyondremote_sync

# OAuth values will come from GitHub/Google provider setup.
PUBLIC_API_BASE_URL=https://api.beyondstudios.us
APP_SECRET=generate_a_long_random_value
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
